---
import type { GitHubUser } from '~/types'

interface Props extends GitHubUser {}

const { avatar_url, bio, followers, login, name, public_repos } = Astro.props
---

<header
  id='header'
  class='border-border bg-card/80 sticky top-0 z-10 border-b backdrop-blur-sm'
>
  <div class='mx-auto max-w-7xl px-4 py-6'>
    <section class='flex flex-col items-center gap-4 sm:flex-row'>
      <article class='shrink-0'>
        <img
          src={avatar_url}
          alt={login}
          class='border-primary/50 h-20 w-20 rounded-full border-2'
        />
      </article>
      <article class='flex-1 text-center sm:text-left'>
        <h1 class='text-foreground text-2xl font-bold'>
          {name || login}
        </h1>
        <p class='text-muted mt-1'>
          {bio || ''}
        </p>
      </article>
      <article class='flex gap-4 text-sm'>
        <div class='bg-secondary rounded-lg px-4 py-2 text-center'>
          <p class='text-foreground font-bold'>
            {public_repos}
          </p>
          <span class='text-muted text-xs'>Repos</span>
        </div>
        <div class='bg-secondary rounded-lg px-4 py-2 text-center'>
          <p class='text-foreground font-bold'>
            {followers}
          </p>
          <span class='text-muted text-xs'>Followers</span>
        </div>
      </article>
    </section>
  </div>
</header>
